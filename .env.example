# Copy secrets to ~/.config/fish/fish.env (never commit real values)

OPENAI_API_KEY=sk-...
FISH_EMBEDDING_MODEL=text-embedding-3-small

# Cloud corpus (mcp-services VM — set by sitehost setup-fish-cloud)
# FISH_DATA_DIR=/data/fish
# FISH_DB_PATH=/data/fish/fish.db

FISH_PASSWORD_SEEHART=app-password-here
FISH_PASSWORD_EVOLVER=app-password-here
FISH_PASSWORD_AGI_GREEN=app-password-here
FISH_PASSWORD_GMAIL=app-password-here

# Optional: remote MCP OAuth (Phase 4)
# FISH_MCP_TRANSPORT=stdio
# FISH_MCP_BASE_URL=https://your-domain.com/fish
# FISH_MCP_CLIENT_ID=fish-mcp
# FISH_MCP_CLIENT_SECRET=change-me
